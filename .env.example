# Database Configuration (Neon PostgreSQL)
# IMPORTANT: Do NOT use the VITE_ prefix here — that would expose the connection string to the browser bundle.
DATABASE_URL=postgresql://username:password@hostname/database?sslmode=require

# JWT Secret (generate a strong random string, min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long

# Optional: Redis URL for persistent rate limiting across serverless instances
# If not set, falls back to in-memory (resets on cold start)
# REDIS_URL=redis://username:password@hostname:6379

# Optional: Frontend URL for CORS whitelist
# FRONTEND_URL=https://your-domain.com

# Optional: Log level (DEBUG | INFO | WARN | ERROR)
LOG_LEVEL=INFO

# Node environment
NODE_ENV=development

# SMTP Configuration for Email Notifications
# Example for Gmail: host=smtp.gmail.com, port=587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@chibivulture.com

# VAPID Keys for Push Notifications
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@chibivulture.com

# Admin Credentials (for admin login)
# IMPORTANT: Use strong, unique credentials in production
ADMIN_EMAIL=papicamara22@gmail.com
ADMIN_PASSWORD=fantasangare2203
