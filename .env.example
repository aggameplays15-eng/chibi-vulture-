# Database Configuration (Neon PostgreSQL)
# IMPORTANT: Do NOT use the VITE_ prefix here — that would expose the connection string to the browser bundle.
DATABASE_URL=postgresql://username:password@hostname/database?sslmode=require

# JWT Secret (generate a strong random string, min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long

# Optional: Redis URL for persistent rate limiting across serverless instances
# If not set, falls back to in-memory (resets on cold start)
# REDIS_URL=redis://username:password@hostname:6379

# Optional: Frontend URL for CORS whitelist
# FRONTEND_URL=https://your-domain.com

# Optional: Log level (DEBUG | INFO | WARN | ERROR)
LOG_LEVEL=INFO

# Node environment
NODE_ENV=development
